# Copy this file to .env and fill in the values.

# ──────────────────────────────────────────────
# Book Database API
# ──────────────────────────────────────────────
BOOKDATABASE_BASE_URL=https://api.bookdatabase.io
BOOKDATABASE_API_KEY=

# ──────────────────────────────────────────────
# Mailtrap (email service)
# ──────────────────────────────────────────────
MAILTRAP_API_BASE_URL=https://send.api.mailtrap.io/api/send
MAILTRAP_API_TOKEN=
MAILTRAP_FROM_EMAIL=no-reply@booksrandomized.local
MAILTRAP_FROM_NAME=Books Randomized

# ──────────────────────────────────────────────
# Translation API
# ──────────────────────────────────────────────
TRANSLATE_API_BASE_URL=
TRANSLATE_API_KEY=

# ──────────────────────────────────────────────
# Frontend
# ──────────────────────────────────────────────
API_BASE_URL=http://localhost:8080/api
